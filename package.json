{
  "name": "cosmo-api",
  "version": "0.1.0",
  "description": "Cosmos.so image scraper + image-search API",
  "type": "module",
  "bin": {
    "cosmos-scrape": "./dist/scrape.js",
    "cosmos-mcp": "./dist/mcp.js"
  },
  "scripts": {
    "dev:server": "tsx src/server.ts",
    "dev:scrape": "tsx src/scrape.ts",
    "dev:mcp": "tsx src/mcp.ts",
    "mcp": "node dist/mcp.js",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=18"
  }
}
